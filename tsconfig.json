{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["dashboard/src/*"]
    }
  },
  "include": ["backend/**/*", "core/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dashboard"]
}
